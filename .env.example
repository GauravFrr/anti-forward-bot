# Telegram Bot Settings
BOT_TOKEN=your_bot_token_here

# Database Settings
POSTGRES_USER=fwbot_admin
POSTGRES_PASSWORD=changeme_strong_password_here
POSTGRES_DB=forward_bot_db

# Connection URLs
# For local running (outside docker):
# DATABASE_URL=postgresql+asyncpg://fwbot_admin:changeme_strong_password_here@localhost:5432/forward_bot_db
# REDIS_URL=redis://:changeme_redis_pass@localhost:6379/0

# For docker execution:
DATABASE_URL=postgresql+asyncpg://fwbot_admin:changeme_strong_password_here@postgres:5432/forward_bot_db
REDIS_URL=redis://:changeme_redis_pass@redis:6379/0

# General Settings
LOG_LEVEL=INFO
OWNER_ID=your_telegram_id_here

